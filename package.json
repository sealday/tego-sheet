{
  "name": "tego-sheet",
  "version": "1.1.8",
  "description": "A React spreadsheet library",
  "type": "module",
  "types": "./dist/index.d.ts",
  "main": "./dist/tego-sheet.cjs",
  "module": "./dist/tego-sheet.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/tego-sheet.js",
      "require": "./dist/tego-sheet.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./locales/en": {
      "types": "./dist/locales/en.d.ts",
      "import": "./dist/locales/en.js",
      "require": "./dist/locales/en.cjs"
    },
    "./locales/de": {
      "types": "./dist/locales/de.d.ts",
      "import": "./dist/locales/de.js",
      "require": "./dist/locales/de.cjs"
    },
    "./locales/nl": {
      "types": "./dist/locales/nl.d.ts",
      "import": "./dist/locales/nl.js",
      "require": "./dist/locales/nl.cjs"
    },
    "./locales/zh-cn": {
      "types": "./dist/locales/zh-cn.d.ts",
      "import": "./dist/locales/zh-cn.js",
      "require": "./dist/locales/zh-cn.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "docs/migration-from-x-data-spreadsheet.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "author": "myliang <liangyuliang0335@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/myliang/x-spreadsheet.git"
  },
  "scripts": {
    "test": "vitest run",
    "test:unit": "vitest run --project unit --project component --project architecture",
    "test:browser": "playwright test tests/browser",
    "test:visual": "playwright test --config playwright.visual.config.ts",
    "test:ssr": "node scripts/test-ssr.mjs",
    "test:package": "node scripts/test-package.mjs",
    "test:parity-gate": "node --test tests/parity/manifest-gate.check.ts && node scripts/verify-parity-manifest.ts test-results/parity-evidence.ndjson",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "lint": "eslint . --max-warnings 0",
    "dev": "vite",
    "build": "vite build",
    "build:demo": "tsc --noEmit --project demo/tsconfig.json && vite build --config demo/vite.config.ts"
  },
  "keywords": [
    "react",
    "spreadsheet",
    "canvas"
  ],
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "jsdom": "29.1.1",
    "less": "4.6.7",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.4",
    "vite-plugin-dts": "5.0.3",
    "vitest": "4.1.10"
  },
  "dependencies": {},
  "peerDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
