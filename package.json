{
  "name": "tego-sheet",
  "version": "0.1.0",
  "description": "A React spreadsheet library",
  "keywords": [
    "canvas",
    "react",
    "spreadsheet"
  ],
  "homepage": "https://github.com/sealday/tego-sheet#readme",
  "bugs": {
    "url": "https://github.com/sealday/tego-sheet/issues"
  },
  "license": "MIT",
  "author": "sealday <sealday@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sealday/tego-sheet.git"
  },
  "files": [
    "dist",
    "docs/migration-from-x-data-spreadsheet.md"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/tego-sheet.cjs",
  "module": "./dist/tego-sheet.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/tego-sheet.js",
      "require": "./dist/tego-sheet.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./locales/en": {
      "types": "./dist/locales/en.d.ts",
      "import": "./dist/locales/en.js",
      "require": "./dist/locales/en.cjs"
    },
    "./locales/de": {
      "types": "./dist/locales/de.d.ts",
      "import": "./dist/locales/de.js",
      "require": "./dist/locales/de.cjs"
    },
    "./locales/nl": {
      "types": "./dist/locales/nl.d.ts",
      "import": "./dist/locales/nl.js",
      "require": "./dist/locales/nl.cjs"
    },
    "./locales/zh-cn": {
      "types": "./dist/locales/zh-cn.d.ts",
      "import": "./dist/locales/zh-cn.js",
      "require": "./dist/locales/zh-cn.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "vitest run",
    "test:unit": "vitest run --project unit --project component --project architecture",
    "test:browser": "playwright test tests/browser",
    "test:visual": "playwright test --config playwright.visual.config.ts",
    "test:ssr": "node scripts/test-ssr.mjs",
    "test:package": "node scripts/test-package.mjs",
    "test:parity-gate": "node scripts/test-parity-gate.mjs",
    "test:parity-release": "node scripts/run-parity-release.mjs",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "lint": "oxlint --deny-warnings .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "prepare": "husky",
    "dev": "vite --config demo/vite.config.ts",
    "build": "vite build",
    "build:demo": "tsc --noEmit --project demo/tsconfig.json && vite build --config demo/vite.config.ts"
  },
  "dependencies": {},
  "devDependencies": {
    "@commitlint/cli": "20.5.3",
    "@commitlint/config-conventional": "20.5.3",
    "@playwright/test": "1.61.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "less": "4.6.7",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript": "6.0.3",
    "vite": "8.1.4",
    "vite-plugin-dts": "5.0.3",
    "vitest": "4.1.10"
  },
  "peerDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "npm@11.13.0"
}
